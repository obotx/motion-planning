<mujocoinclude>
    <actuator>

        <!--  === ARM 1 FINGER ACTUATORS === -->
        <!--  kv adds derivative damping (kv=20 critical for kp=100 j1, kv=6 for kp=10 j2/j3/palm). -->
        <position joint="finger_c_joint_1_1" name="finger_c_joint_1_1" ctrlrange="-2.0 1.2218" kp="100" kv="20"/>
        <position joint="finger_c_joint_2_1" name="finger_c_joint_2_1" ctrlrange="0 1.5708" kp="10" kv="6"/>
        <position joint="finger_c_joint_3_1" name="finger_c_joint_3_1" ctrlrange="-1.2217 -0.0523" kp="10" kv="6"/>
        <position joint="finger_b_joint_1_1" name="finger_b_joint_1_1" ctrlrange="-2.0 1.2218" kp="100" kv="20"/>
        <position joint="finger_b_joint_2_1" name="finger_b_joint_2_1" ctrlrange="0 1.5708" kp="10" kv="6"/>
        <position joint="finger_b_joint_3_1" name="finger_b_joint_3_1" ctrlrange="-1.2217 -0.0523" kp="10" kv="6"/>
        <position joint="finger_a_joint_1_1" name="finger_a_joint_1_1" ctrlrange="-1.5 1.2218" kp="100" kv="20"/>
        <position joint="finger_a_joint_2_1" name="finger_a_joint_2_1" ctrlrange="0 1.5708" kp="10" kv="6"/>
        <position joint="finger_a_joint_3_1" name="finger_a_joint_3_1" ctrlrange="-1.2217 -0.0523" kp="10" kv="6"/>
        <position joint="palm_finger_c_joint_1" name="palm_finger_c_joint_1" ctrlrange="-0.1784 0.192" kp="10" kv="6"/>
        <position joint="palm_finger_b_joint_1" name="palm_finger_b_joint_1" ctrlrange="-0.192 0.1784" kp="10" kv="6"/>

        <position name="wrist_X_1" joint="gripper_x_rotation_1" ctrlrange="-0.8 0.8" kp="500" kv="10"/>
        <position name="wrist_Y_1" joint="gripper_y_rotation_1" ctrlrange="-0.8 0.8" kp="500" kv="10"/>
        <position name="wrist_Z_1" joint="gripper_z_rotation_1" ctrlrange="-3.14159 3.14159" kp="500" kv="10"/>
        <position name="HandBearing_1" joint="HandBearingJoint_1" ctrlrange="-1.57 1.57" kp="500" kv="10"/>

        <!--  === ARM 2 FINGER ACTUATORS === -->
        <position joint="finger_c_joint_1_2" name="finger_c_joint_1_2" ctrlrange="-2.0 1.2218" kp="100" kv="20"/>
        <position joint="finger_c_joint_2_2" name="finger_c_joint_2_2" ctrlrange="0 1.5708" kp="10" kv="6"/>
        <position joint="finger_c_joint_3_2" name="finger_c_joint_3_2" ctrlrange="-1.2217 -0.0523" kp="10" kv="6"/>
        <position joint="finger_b_joint_1_2" name="finger_b_joint_1_2" ctrlrange="-2.0 1.2218" kp="100" kv="20"/>
        <position joint="finger_b_joint_2_2" name="finger_b_joint_2_2" ctrlrange="0 1.5708" kp="10" kv="6"/>
        <position joint="finger_b_joint_3_2" name="finger_b_joint_3_2" ctrlrange="-1.2217 -0.0523" kp="10" kv="6"/>
        <position joint="finger_a_joint_1_2" name="finger_a_joint_1_2" ctrlrange="-1.5 1.2218" kp="100" kv="20"/>
        <position joint="finger_a_joint_2_2" name="finger_a_joint_2_2" ctrlrange="0 1.5708" kp="10" kv="6"/>
        <position joint="finger_a_joint_3_2" name="finger_a_joint_3_2" ctrlrange="-1.2217 -0.0523" kp="10" kv="6"/>
        <position joint="palm_finger_c_joint_2" name="palm_finger_c_joint_2" ctrlrange="-0.1784 0.192" kp="10" kv="6"/>
        <position joint="palm_finger_b_joint_2" name="palm_finger_b_joint_2" ctrlrange="-0.192 0.1784" kp="10" kv="6"/>

        <position name="wrist_X_2" joint="gripper_x_rotation_2" ctrlrange="-0.8 0.8" kp="500" kv="10"/>
        <position name="wrist_Y_2" joint="gripper_y_rotation_2" ctrlrange="-0.8 0.8" kp="500" kv="10"/>
        <position name="wrist_Z_2" joint="gripper_z_rotation_2" ctrlrange="-3.14159 3.14159" kp="500" kv="10"/>
        <position name="HandBearing_2" joint="HandBearingJoint_2" ctrlrange="-1.57 1.57" kp="500" kv="10"/>

    </actuator>
</mujocoinclude>